# Local development can set DEBUG=True. Production/Vercel must keep DEBUG=False.
DEBUG=True
SECRET_KEY=replace-with-a-long-random-secret-at-least-50-characters

# Local hosts. In Vercel, VERCEL_URL is detected automatically; add custom domains here.
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Supabase/PostgreSQL. Prefer DATABASE_URL on Vercel.
# Use the Supabase transaction pooler URL for serverless deployments:
# postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
DB_SSL_REQUIRE=True
DB_CONN_MAX_AGE=0
DB_DISABLE_SERVER_SIDE_CURSORS=True
DB_DISABLE_PREPARED_STATEMENTS=True

# Component fallback if you do not use DATABASE_URL.
DB_NAME=postgres
DB_USER=postgres.PROJECT_REF
DB_PASSWORD=replace-later
DB_HOST=aws-REGION.pooler.supabase.com
DB_PORT=6543

# Vercel build-time database bootstrap. Enable only after DB credentials are set.
RUN_DEPLOY_MIGRATIONS=False
RUN_DEPLOY_SEED=True
RUN_DEPLOY_CHECKS=True

# Security/session controls.
PASSWORD_MIN_LENGTH=12
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
CSRF_COOKIE_HTTPONLY=True
ADMIN_URL=admin/

# API/CORS/AI.
CORS_ALLOWED_ORIGINS=
DRF_ANON_RATE=100/day
DRF_USER_RATE=1000/day
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
AI_DAILY_LIMIT=25

REDIS_URL=redis://localhost:6379/0
TIME_ZONE=Africa/Douala
